# ==============================================================================
# ShrFlow — Production Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Update each variable below with your project-specific credentials.
# 3. DO NOT commit your actual .env file to version control.
# ==============================================================================

# ── 1. INFRASTRUCTURE: SUPABASE (Database, Auth, Storage) ─────────────────────
# Core backend infrastructure for data persistence and authentication.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key

# Database Connection (Direct PostgreSQL)
# Required for running migrations and backend service connections.
# Format: postgresql://[user]:[password]@[host]:[port]/postgres
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# ── 2. MESSAGING & SIGNALING ──────────────────────────────────────────────────
# RabbitMQ: Used for asynchronous task orchestration (Importing & Dispatching).
RABBITMQ_URL=amqps://[user]:[password]@[host]/[vhost]

# Redis: Used for campaign state management, rate limiting, and tracking signatures.
REDIS_URL=rediss://default:[password]@[host]:[port]

# ── 3. EMAIL DELIVERY PIPELINES ──────────────────────────────────────────────
# PIPELINE A: Marketing & Bulk Campaigns (Recommended: Amazon SES)
SMTP_HOST=email-smtp.[region].amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your_ses_smtp_username
SMTP_PASSWORD=your_ses_smtp_password

# PIPELINE B: System & Transactional Mail (Used for OTPs, Invites, Resets)
# NOTE: Gmail SMTP is for TEMPORARY/DEVELOPMENT use only.
# For production, you MUST migrate this to a dedicated provider (e.g. AWS SES).
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USERNAME=your-admin-email@gmail.com
SYSTEM_SMTP_PASSWORD=your_16_char_google_app_password
SYSTEM_SMTP_FROM_EMAIL=no-reply@yourdomain.com
SYSTEM_SMTP_FROM_NAME=ShrFlow Admin

# Alternative: AWS SES for Pipeline B (Recommended for Production)
# SYSTEM_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SYSTEM_SMTP_PORT=587
# SYSTEM_SMTP_USERNAME=your_ses_username
# SYSTEM_SMTP_PASSWORD=your_ses_password

# ── 4. TRACKING & ANALYTICS (Edge Functions) ──────────────────────────────────
# The base URL for Supabase Edge Functions (e.g. https://xyz.supabase.co/functions/v1)
# Used for:
# - Tracking pixel: {API_URL}/track/open/{id}?s={sig}
# - Click redirect: {API_URL}/track/click?d=...
API_URL=https://your-project-id.supabase.co/functions/v1

# HMAC Secret used to sign and verify tracking pixels
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TRACKING_SECRET=generate_a_secure_hex_key_here

# ── 5. FILE STORAGE (Supabase S3) ─────────────────────────────────────────────
# Configuration for handling CSV imports and asset storage.
STORAGE_TYPE=s3
S3_BUCKET=imports
S3_REGION=your-region
S3_ENDPOINT=https://your-project-id.supabase.co/storage/v1/s3

# AWS Credentials (used for both SES and S3 Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your-region

# ── 6. SECURITY & AUTHENTICATION ──────────────────────────────────────────────
# JWT Secret for backend authentication
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_secure_generated_key

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=your_google_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_secret
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret

# ── 7. NETWORKING & ROUTING ───────────────────────────────────────────────────
# Base URLs for the API and Frontend components
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Client-side Supabase keys (Safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# ── 8. SYSTEM LOGGING & ENVIRONMENT ───────────────────────────────────────────
DEBUG=True
ENVIRONMENT=development
TRACE_ID_HEADER=X-Trace-ID

# ── 9. ANTI-SPAM (reCAPTCHA) ──────────────────────────────────────────────────
CAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=your_recaptcha_secret
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
